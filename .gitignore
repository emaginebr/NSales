## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
/Backend/NSales/*.rsuser
/Backend/NSales/*.suo
/Backend/NSales/*.user
/Backend/NSales/*.userosscache
/Backend/NSales/*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
/Backend/NSales/*.userprefs

# Mono auto generated files
/Backend/NSales/mono_crash.*

# Build results
/Backend/NSales/[Dd]ebug/
/Backend/NSales/[Dd]ebugPublic/
/Backend/NSales/[Rr]elease/
/Backend/NSales/[Rr]eleases/
/Backend/NSales/x64/
/Backend/NSales/x86/
/Backend/NSales/[Ww][Ii][Nn]32/
/Backend/NSales/[Aa][Rr][Mm]/
/Backend/NSales/[Aa][Rr][Mm]64/
/Backend/NSales/bld/
/Backend/NSales/[Bb]in/
/Backend/NSales/[Oo]bj/
/Backend/NSales/[Ll]og/
/Backend/NSales/[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
/Backend/NSales/.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio 2017 auto generated files
/Backend/NSales/Generated\ Files/

# MSTest test Results
/Backend/NSales/[Tt]est[Rr]esult*/
/Backend/NSales/[Bb]uild[Ll]og.*

# NUnit
/Backend/NSales/*.VisualState.xml
/Backend/NSales/TestResult.xml
/Backend/NSales/nunit-*.xml

# Build Results of an ATL Project
/Backend/NSales/[Dd]ebugPS/
/Backend/NSales/[Rr]eleasePS/
/Backend/NSales/dlldata.c

# Benchmark Results
/Backend/NSales/BenchmarkDotNet.Artifacts/

# .NET Core
/Backend/NSales/project.lock.json
/Backend/NSales/project.fragment.lock.json
/Backend/NSales/artifacts/

# ASP.NET Scaffolding
/Backend/NSales/ScaffoldingReadMe.txt

# StyleCop
/Backend/NSales/StyleCopReport.xml

# Files built by Visual Studio
/Backend/NSales/*_i.c
/Backend/NSales/*_p.c
/Backend/NSales/*_h.h
/Backend/NSales/*.ilk
/Backend/NSales/*.meta
/Backend/NSales/*.obj
/Backend/NSales/*.iobj
/Backend/NSales/*.pch
/Backend/NSales/*.pdb
/Backend/NSales/*.ipdb
/Backend/NSales/*.pgc
/Backend/NSales/*.pgd
/Backend/NSales/*.rsp
# but not Directory.Build.rsp, as it configures directory-level build defaults
/Backend/NSales/!Directory.Build.rsp
/Backend/NSales/*.sbr
/Backend/NSales/*.tlb
/Backend/NSales/*.tli
/Backend/NSales/*.tlh
/Backend/NSales/*.tmp
/Backend/NSales/*.tmp_proj
/Backend/NSales/*_wpftmp.csproj
/Backend/NSales/*.log
/Backend/NSales/*.tlog
/Backend/NSales/*.vspscc
/Backend/NSales/*.vssscc
/Backend/NSales/.builds
/Backend/NSales/*.pidb
/Backend/NSales/*.svclog
/Backend/NSales/*.scc

# Chutzpah Test files
/Backend/NSales/_Chutzpah*

# Visual C++ cache files
/Backend/NSales/ipch/
/Backend/NSales/*.aps
/Backend/NSales/*.ncb
/Backend/NSales/*.opendb
/Backend/NSales/*.opensdf
/Backend/NSales/*.sdf
/Backend/NSales/*.cachefile
/Backend/NSales/*.VC.db
/Backend/NSales/*.VC.VC.opendb

# Visual Studio profiler
/Backend/NSales/*.psess
/Backend/NSales/*.vsp
/Backend/NSales/*.vspx
/Backend/NSales/*.sap

# Visual Studio Trace Files
/Backend/NSales/*.e2e

# TFS 2012 Local Workspace
/Backend/NSales/$tf/

# Guidance Automation Toolkit
/Backend/NSales/*.gpState

# ReSharper is a .NET coding add-in
/Backend/NSales/_ReSharper*/
/Backend/NSales/*.[Rr]e[Ss]harper
/Backend/NSales/*.DotSettings.user

# TeamCity is a build add-in
/Backend/NSales/_TeamCity*

# DotCover is a Code Coverage Tool
/Backend/NSales/*.dotCover

# AxoCover is a Code Coverage Tool
/Backend/NSales/.axoCover/*
/Backend/NSales/!.axoCover/settings.json

# Coverlet is a free, cross platform Code Coverage Tool
/Backend/NSales/coverage*.json
/Backend/NSales/coverage*.xml
/Backend/NSales/coverage*.info

# Visual Studio code coverage results
/Backend/NSales/*.coverage
/Backend/NSales/*.coveragexml

# NCrunch
/Backend/NSales/_NCrunch_*
/Backend/NSales/.NCrunch_*
/Backend/NSales/.*crunch*.local.xml
/Backend/NSales/nCrunchTemp_*

# MightyMoose
/Backend/NSales/*.mm.*
/Backend/NSales/AutoTest.Net/

# Web workbench (sass)
/Backend/NSales/.sass-cache/

# Installshield output folder
/Backend/NSales/[Ee]xpress/

# DocProject is a documentation generator add-in
/Backend/NSales/DocProject/buildhelp/
/Backend/NSales/DocProject/Help/*.HxT
/Backend/NSales/DocProject/Help/*.HxC
/Backend/NSales/DocProject/Help/*.hhc
/Backend/NSales/DocProject/Help/*.hhk
/Backend/NSales/DocProject/Help/*.hhp
/Backend/NSales/DocProject/Help/Html2
/Backend/NSales/DocProject/Help/html

# Click-Once directory
/Backend/NSales/publish/

# Publish Web Output
/Backend/NSales/*.[Pp]ublish.xml
/Backend/NSales/*.azurePubxml
# Note: Comment the next line if you want to checkin your web deploy settings,
# but database connection strings (with potential passwords) will be unencrypted
/Backend/NSales/*.pubxml
/Backend/NSales/*.publishproj

# Microsoft Azure Web App publish settings. Comment the next line if you want to
# checkin your Azure Web App publish settings, but sensitive information contained
# in these scripts will be unencrypted
/Backend/NSales/PublishScripts/

# NuGet Packages
/Backend/NSales/*.nupkg
# NuGet Symbol Packages
/Backend/NSales/*.snupkg
# The packages folder can be ignored because of Package Restore
/Backend/NSales/**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
/Backend/NSales/!**/[Pp]ackages/build/
# Uncomment if necessary however generally it will be regenerated when needed
#!**/[Pp]ackages/repositories.config
# NuGet v3's project.json files produces more ignorable files
/Backend/NSales/*.nuget.props
/Backend/NSales/*.nuget.targets

# Microsoft Azure Build Output
/Backend/NSales/csx/
/Backend/NSales/*.build.csdef

# Microsoft Azure Emulator
/Backend/NSales/ecf/
/Backend/NSales/rcf/

# Windows Store app package directories and files
/Backend/NSales/AppPackages/
/Backend/NSales/BundleArtifacts/
/Backend/NSales/Package.StoreAssociation.xml
/Backend/NSales/_pkginfo.txt
/Backend/NSales/*.appx
/Backend/NSales/*.appxbundle
/Backend/NSales/*.appxupload

# Visual Studio cache files
# files ending in .cache can be ignored
/Backend/NSales/*.[Cc]ache
# but keep track of directories ending in .cache
/Backend/NSales/!?*.[Cc]ache/

# Others
/Backend/NSales/ClientBin/
/Backend/NSales/~$*
/Backend/NSales/*~
/Backend/NSales/*.dbmdl
/Backend/NSales/*.dbproj.schemaview
/Backend/NSales/*.jfm
#*.pfx
/Backend/NSales/*.publishsettings
/Backend/NSales/orleans.codegen.cs

# Including strong name files can present a security risk
# (https://github.com/github/gitignore/pull/2483#issue-259490424)
#*.snk

# Since there are multiple workflows, uncomment next line to ignore bower_components
# (https://github.com/github/gitignore/pull/1529#issuecomment-104372622)
#bower_components/

# RIA/Silverlight projects
/Backend/NSales/Generated_Code/

# Backup & report files from converting an old project file
# to a newer Visual Studio version. Backup files are not needed,
# because we have git ;-)
/Backend/NSales/_UpgradeReport_Files/
/Backend/NSales/Backup*/
/Backend/NSales/UpgradeLog*.XML
/Backend/NSales/UpgradeLog*.htm
/Backend/NSales/ServiceFabricBackup/
/Backend/NSales/*.rptproj.bak

# SQL Server files
/Backend/NSales/*.mdf
/Backend/NSales/*.ldf
/Backend/NSales/*.ndf

# Business Intelligence projects
/Backend/NSales/*.rdl.data
/Backend/NSales/*.bim.layout
/Backend/NSales/*.bim_*.settings
/Backend/NSales/*.rptproj.rsuser
/Backend/NSales/*- [Bb]ackup.rdl
/Backend/NSales/*- [Bb]ackup ([0-9]).rdl
/Backend/NSales/*- [Bb]ackup ([0-9][0-9]).rdl

# Microsoft Fakes
/Backend/NSales/FakesAssemblies/

# GhostDoc plugin setting file
/Backend/NSales/*.GhostDoc.xml

# Node.js Tools for Visual Studio
/Backend/NSales/.ntvs_analysis.dat
/Backend/NSales/node_modules/

# Visual Studio 6 build log
/Backend/NSales/*.plg

# Visual Studio 6 workspace options file
/Backend/NSales/*.opt

# Visual Studio 6 auto-generated workspace file (contains which files were open etc.)
