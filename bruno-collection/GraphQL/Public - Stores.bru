meta {
  name: Public - Stores
  type: graphql
  seq: 1
}

post {
  url: {{baseUrl}}/graphql
  body: graphql
  auth: none
}

body:graphql {
  {
    stores {
      storeId
      name
      slug
      logo
      logoUrl
      status
      products {
        productId
        name
        price
        imageUrl
      }
    }
  }
}
